# Copie para .env.local e preencha. NUNCA versione o .env.local.

# --- Obrigatórias ---
# String de conexão PostgreSQL (ex.: Neon — https://neon.tech, plano grátis serve)
DATABASE_URL="postgresql://usuario:senha@host/db?sslmode=require"
# Senha de acesso ao app (gate de login)
APP_PASSCODE="troque-esta-senha"

# --- Tutor de IA (opcional) ---
# Chave do Google AI Studio (grátis): https://aistudio.google.com
GOOGLE_GEMINI_API_KEY=""
# Alternativa: usar Claude (Anthropic) em vez do Gemini
# ANTHROPIC_API_KEY="sk-ant-..."

# --- Figuras das questões (opcional; só nas provas reais, não na demo) ---
# URL base pública do Vercel Blob (em produção)
NEXT_PUBLIC_BLOB_BASE=""
# Token de escrita do Vercel Blob (usado por `npm run blob:upload`)
BLOB_READ_WRITE_TOKEN=""
